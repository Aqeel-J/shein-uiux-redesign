<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ShippingInfoActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="@dimen/header_height"
        android:paddingHorizontal="@dimen/padding_20"
        android:background="@color/white"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnReturnHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:padding="0dp"
            android:background="@color/transparent"
            android:src="@drawable/ic_chevron_left_fill"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="@dimen/header_1"
            android:fontFamily="@font/poppins_semi_bold"
            android:textColor="@color/black"
            android:text="Shipping Info"/>

        <ImageButton
            android:id="@+id/btnShoppingBag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@color/transparent"
            android:src="@drawable/ic_shopping_outlined"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gray_400"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="fill_parent"
        android:scrollbars="none"
        android:layout_marginTop="@dimen/header_height"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_20">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginBottom="@dimen/margin_20"
                android:fontFamily="@font/poppins"
                android:textSize="@dimen/body"
                android:textColor="@color/gray_600"
                android:text="Ship from Global (1-3 days for processing)"/>

            <!-- Table -->
            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_20"
                android:layout_gravity="center">

                <TableRow
                    android:background="@color/off_white">
                    <TextView
                        android:layout_gravity="center|start"
                        android:padding="@dimen/padding_20"
                        android:fontFamily="@font/poppins"
                        android:textSize="@dimen/body"
                        android:textColor="@color/black"
                        android:text="Shipping\nMethod"/>

                    <TextView
                        android:layout_gravity="center|start"
                        android:padding="@dimen/padding_20"
                        android:fontFamily="@font/poppins"
                        android:textSize="@dimen/body"
                        android:textColor="@color/black"
                        android:text="Shipping Time"/>

                    <TextView
                        android:layout_gravity="center|start"
                        android:padding="@dimen/padding_20"
                        android:fontFamily="@font/poppins"
                        android:textSize="@dimen/body"
                        android:textColor="@color/black"
                        android:text="Cost"/>
                </TableRow>

                <TableRow>
                    <TextView
                        android:layout_gravity="center|start"
                        android:padding="@dimen/padding_20"
                        android:fontFamily="@font/poppins"
                        android:textSize="@dimen/body"
                        android:text="Standard\nShipping"/>

                    <TextView
                        android:layout_gravity="center|start"
                        android:padding="@dimen/padding_20"
                        android:fontFamily="@font/poppins"
                        android:textSize="@dimen/body"
                        android:text="Estimated To Be Delivered\nOn 04/1/2023 - 04/25/2023."/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_medium"
                            android:paddingTop="@dimen/padding_20"
                            android:paddingHorizontal="@dimen/padding_20"
                            android:text="$6.99"
                            android:textSize="@dimen/body" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_medium"
                            android:textColor="@color/red"
                            android:paddingBottom="@dimen/padding_20"
                            android:paddingHorizontal="@dimen/padding_20"
                            android:text="Free -\norders over\n$50.00"
                            android:textSize="@dimen/body"/>
                    </LinearLayout>

                </TableRow>
            </TableLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/body"
                android:lineSpacingExtra="6sp"
                android:text="@string/shipping_info"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_medium"
                android:textColor="@color/red"
                android:textSize="@dimen/body"
                android:lineSpacingExtra="6sp"
                android:text="@string/shipping_info_red"/>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>