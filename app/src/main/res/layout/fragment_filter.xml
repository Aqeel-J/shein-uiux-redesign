<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    tools:context=".fragments.FilterFragment">

    <!-- Header -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/header_height">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Filter"
            android:textColor="@color/black_400"
            android:textSize="@dimen/header_1" />

        <ImageButton
            android:id="@+id/btnCloseFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="right"
            android:layout_margin="@dimen/margin_20"
            android:background="@color/transparent"
            android:src="@drawable/ic_close_fill" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_gravity="bottom"
            android:background="@color/gray_400" />
    </FrameLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginVertical="@dimen/header_height">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="true"
            android:padding="@dimen/padding_20"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_semi_bold"
                android:text="Size"
                android:textColor="@color/black_400"
                android:textSize="@dimen/header_1" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.Dense.ExposedDropdownMenu"
                app:boxBackgroundColor="@color/transparent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Select Category">

                <AutoCompleteTextView
                    android:id="@+id/autoCompleteCategoryList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_semi_bold"
                android:text="Size"
                android:layout_marginTop="@dimen/spacing_before_12"
                android:textColor="@color/black_400"
                android:textSize="@dimen/header_1" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>