<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/off_white"
    tools:context=".CategoryActivity">

    <!-- App Logo Layout -->
    <LinearLayout
        android:id="@+id/app_logo_frame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <!-- Header -->
        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="60dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="16dp">

            <!-- Message Button -->
            <ImageButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/transparent"
                android:padding="0dp"
                android:src="@drawable/ic_mail_outlined"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- This view with weight 1 as a flex space to evenly space out other views -->
            <View
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <!-- Favorites Button -->
            <ImageButton
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="@color/transparent"
                android:padding="0dp"
                android:src="@drawable/ic_favorite_outlined" />

        </LinearLayout>

        <ImageView
            android:id="@+id/app_logo"
            android:layout_width="match_parent"
            android:layout_height="@dimen/header_height"
            android:layout_gravity="center"
            android:src="@drawable/ic_shein_logo" />

        <!-- Search Field -->
        <EditText
            android:id="@+id/txtSearch"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginHorizontal="50dp"
            android:background="@drawable/round_white_textfield"
            android:drawableLeft="@drawable/ic_search_textfield"
            android:drawableRight="@drawable/ic_camera_textfield"
            android:drawablePadding="16dp"
            android:gravity="center|left"
            android:hint="Search"
            android:paddingHorizontal="@dimen/padding_20"
            android:textColor="@color/gray_600"
            android:textSize="@dimen/header_2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/app_logo_frame" />
        
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/categoryRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_20"
            android:paddingTop="@dimen/padding_20"
            android:paddingBottom="@dimen/header_height" />

    </LinearLayout>

    <!-- Bottom Navigation -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom">
        <!-- Bottom Navigation -->
        <LinearLayout
            android:id="@+id/NavigationGrid"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_gravity="bottom"
            android:background="@drawable/ic_nav_background"
            android:gravity="center">

            <!-- Home Button -->
            <ImageButton
                android:id="@+id/btnHome"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:background="@color/transparent"
                android:src="@drawable/ic_home_outlined" />

            <!-- Category Button -->
            <ImageButton
                android:id="@+id/btnCategory"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_marginLeft="50dp"
                android:background="@color/transparent"
                android:src="@drawable/ic_category_fill" />

            <!-- Shopping Bag Button -->
            <ImageButton
                android:id="@+id/btnShoppingBag"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_marginLeft="150dp"
                android:background="@color/transparent"
                android:src="@drawable/ic_shopping_outlined" />

            <!-- Account Button-->
            <ImageButton
                android:id="@+id/btnAccount"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_marginLeft="50dp"
                android:background="@color/transparent"
                android:src="@drawable/ic_person_outlined" />

        </LinearLayout>

        <!-- New Product Button Overlay -->
        <LinearLayout
            android:id="@+id/linearLayout3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center">

            <!-- New Products Button -->
            <ImageButton
                android:id="@+id/btnNewProducts"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginVertical="10dp"
                android:background="@color/transparent"
                android:src="@drawable/ic_new_products" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/SearchFragmentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</FrameLayout>